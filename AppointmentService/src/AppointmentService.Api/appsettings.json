{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "OrderMongo": "mongodb://[user]:[password]@localhost:27017"
  },
  "RepositoryType" : "Mongo",
  "MongoDB": {
    "DatabaseName": "OrderDb",
    "Port": 27017
  },
  "Services": {
    "CustomerService": "http://localhost:8080",
    "ProductService": "http://localhost:8080",
    "PaymentService": "http://localhost:8080"
  },
  "Secrets": {
    "ProviderName": "HashiCorpVault",
    "Vault": {
      "Address": "http://localhost:8200",
      "RoleId": "abc123",
      "SecretId": "abc123",
      "AppRoleMountPoint": "approle",
      "KvMountPoint": "app-secrets",
      "SecretPath": "dev/order-service",
      "ReloadOnEachRead": false,
      "CacheTtlSeconds": 30
    },
    "SecretsManager": {
      "SecretName": "dev/order-service",
      "Region": "us-east-1"
    }
  },
  "AllowedHosts": "*"
}
