{
  "ReverseProxy": {
    "Routes": {
      "patientServiceRoute": {
        "ClusterId": "patientCluster",
        "Match": {
          "Methods": [ "GET", "POST", "PUT" ],
          "Path": "/api/patients/{**catch-all}"
        }
      },
      "doctorServiceRoute": {
        "ClusterId": "doctorCluster",
        "Match": {
          "Methods": [ "GET", "POST", "PUT" ],
          "Path": "/api/doctors/{**catch-all}"
        }
      },
      "appointmentServiceRoute": {
        "ClusterId": "appointmentCluster",
        "Match": {
          "Methods": [ "GET", "POST", "PUT" ],
          "Path": "/api/appointments/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "patientCluster": {
        "Destinations": {
          "server1": {
            "Address": "https://localhost:7000/"
          }
        }
      },
      "doctorCluster": {
        "Destinations": {
          "server1": {
            "Address": "https://localhost:7001/"
          }
        }
      },
      "appointmentCluster": {
        "Destinations": {
          "server1": {
            "Address": "https://localhost:7002/"
          }
        }
      }
    }
  }
}